# Получить на https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# Имя файла сессии (создастся при export_session.py --fresh)
SESSION_NAME=dvpro

# Строка сессии (после export_session.py). true = использовать строку, false = только файл
USE_SESSION_STRING=true
# SESSION_STRING=

# Zapret + Warp + tg-ws-proxy работают на уровне системы — прокси в .env не нужен

# LeoMatch
LEO_BOT_USERNAME=leomatchbot
DB_PATH=data/leomatch.db
MEDIA_DIR=data/media
